# InsureIndex AI - Environment Configurations

# (Optional) Set your Gemini API key to enable high-fidelity natural language answering.
# If this key is not set, the RAG pipeline will fallback to a local rule-based extractor
# which yields 100% grounded facts with zero hallucinations.
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here

# (Optional) Set your Groq API key if you want to use Groq LLMs.
GROQ_API_KEY=your_groq_api_key_here

# (Optional) Point this to your specific PDF folder or zip file.
# If left empty, the server automatically scans "Policy Documents" in the project root.
# POLICY_DOCS_SOURCE=C:\Users\ADMIN\OneDrive\Documents\CAPSTONE\Policy Documents
