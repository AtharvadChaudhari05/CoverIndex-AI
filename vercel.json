{
  "version": 2,
  "outputDirectory": "web",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "cache/**|policy_rag/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
