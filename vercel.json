{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": "cache/page_index.json",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/web/$1" }
  ]
}
