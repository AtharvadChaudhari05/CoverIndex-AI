{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{cache,policy_rag}/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/",           "destination": "/web/index.html" },
    { "source": "/index.html", "destination": "/web/index.html" },
    { "source": "/(.*)",       "destination": "/web/$1" }
  ]
}
